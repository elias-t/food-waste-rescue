{
	"info": {
		"name": "Food Waste Rescue API",
		"description": "Complete test collection for the Food Waste Rescue Platform API. Includes auto token capture on login/register.",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"item": [
		{
			"name": "Auth",
			"item": [
				{
					"name": "Register Donor",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"if (pm.response.code === 200) {",
									"    const response = pm.response.json();",
									"    const token = response.value || response.token || response;",
									"    pm.environment.set('jwt_token', token);",
									"    pm.environment.set('donor_email', pm.variables.replaceIn('{{donor_email}}'));",
									"    console.log('Donor token saved');",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"email\": \"{{donor_email}}\",\n  \"password\": \"Donor123!\",\n  \"displayName\": \"Mario's Pizzeria\",\n  \"organisationName\": \"Mario's Pizzeria Ltd\",\n  \"role\": \"Donor\"\n}"
						},
						"url": {
							"raw": "{{base_url}}/api/auth/register",
							"host": ["{{base_url}}"],
							"path": ["api", "auth", "register"]
						}
					}
				},
				{
					"name": "Register Claimer",
					"event": [
						{
							"listen": "test",
