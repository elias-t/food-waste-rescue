		{
			"name": "Listings",
			"item": [
				{
					"name": "Create Listing (Donor)",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"if (pm.response.code === 200) {",
									"    const response = pm.response.json();",
									"    const id = response.value || response.id;",
									"    pm.environment.set('listing_id', id);",
									"    console.log('Listing ID saved: ' + id);",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							},
							{
								"key": "Authorization",
								"value": "Bearer {{jwt_token}}"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"title\": \"Fresh Bread - End of Day\",\n  \"description\": \"Assorted sourdough, baguettes and rolls from today's bake. Perfect condition.\",\n  \"category\": \"Bakery\",\n  \"quantityDescription\": \"Approx 15 loaves and 20 rolls\",\n  \"expiresAt\": \"2026-04-25T20:00:00Z\",\n  \"latitude\": 37.9838,\n  \"longitude\": 23.7275,\n  \"address\": \"Mario's Pizzeria, Athens\"\n}"
						},
						"url": {
							"raw": "{{base_url}}/api/listings",
							"host": ["{{base_url}}"],
							"path": ["api", "listings"]
						}
					}
				},
				{
					"name": "Get Nearby Listings",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{base_url}}/api/listings/nearby?latitude=37.9838&longitude=23.7275&radiusKm=10",
							"host": ["{{base_url}}"],
							"path": ["api", "listings", "nearby"],
							"query": [
								{ "key": "latitude", "value": "37.9838" },
								{ "key": "longitude", "value": "23.7275" },
								{ "key": "radiusKm", "value": "10" }
							]
						}
					}
				},
				{
					"name": "Get Listing Detail",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{base_url}}/api/listings/{{listing_id}}",
							"host": ["{{base_url}}"],
							"path": ["api", "listings", "{{listing_id}}"]
						}
					}
				},
				{
					"name": "Claim Listing (Claimer)",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							},
							{
								"key": "Authorization",
								"value": "Bearer {{jwt_token}}"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"listingId\": \"{{listing_id}}\",\n  \"notes\": \"Will collect at 7pm, coming by van\"\n}"
						},
						"url": {
							"raw": "{{base_url}}/api/listings/{{listing_id}}/claim",
							"host": ["{{base_url}}"],
							"path": ["api", "listings", "{{listing_id}}", "claim"]
						}
					}
				},
				{
					"name": "Cancel Listing (Donor)",
					"request": {
						"method": "DELETE",
						"header": [
							{
								"key": "Authorization",
								"value": "Bearer {{jwt_token}}"
							}
						],
						"url": {
							"raw": "{{base_url}}/api/listings/{{listing_id}}",
							"host": ["{{base_url}}"],
							"path": ["api", "listings", "{{listing_id}}"]
						}
					}
				}
			]
		},
